# MCA Brain System 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# ==================== 数据库配置 ====================
# DATABASE_URL=postgresql://user:password@localhost:5432/mca_db

# ==================== Redis 配置 ====================
REDIS_URL=redis://localhost:6379/0

# ==================== Consul 配置 ====================
CONSUL_HOST=127.0.0.1
CONSUL_PORT=8500
CONSUL_KEY_PREFIX=brain/config

# ==================== 安全配置 ====================
# DLC 签名公钥文件路径（多个用逗号分隔）
# DLC_PUBLIC_KEY_PEM_FILES=/path/to/key1.pem,/path/to/key2.pem

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_JSON=false

# ==================== 可观测性配置 ====================
ENABLE_METRICS=false
ENABLE_TRACING=false
SERVICE_NAME=brain

# ==================== 高可用配置 ====================
LEADER_ELECTION_ENABLED=false
LEADER_LOCK_KEY=brain:leader
LEADER_TTL_SECONDS=10
